      "Skill(shipkit-engineering-goals)",
      "Skill(shipkit-semantic-qa)",
      "Skill(shipkit-qa-visual)",
      "Skill(shipkit-orch-direction)",
      "Skill(shipkit-orch-planning)",
      "Skill(shipkit-orch-shipping)",
