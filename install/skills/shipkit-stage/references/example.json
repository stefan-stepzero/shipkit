{
  "_comment": "Example: WorksheetForge strategic goals (v5.0) — MVP → Scale",

  "$schema": "shipkit-artifact",
  "type": "goals-strategic",
  "version": "5.0",
  "lastUpdated": "2026-03-03T12:00:00Z",
  "source": "shipkit-stage",

  "stage": {
    "current": "mvp",
    "target": "scale"
  },

  "constraints": {
    "quality": "production-ready — CI/CD, monitoring, error handling",
    "scope": "feature-complete for launch segment",
    "cost_budget": "moderate — dedicated resources acceptable"
  },

  "stageImplications": {
    "skip": ["scale testing", "enterprise features", "multi-region deploy"],
    "focus": ["launch readiness", "user experience", "reliability"],
    "qualityBar": "works for customers"
  },

  "derivedFrom": {
    "why": ".shipkit/why.json"
  },

  "criteria": [
    {
      "id": "S-001",
      "name": "User acquisition",
      "category": "business-metric",
      "metric": "Daily active users",
      "threshold": "> 100 DAU within 30 days of launch",
      "rubric": [
        { "range": "< 10 DAU", "meaning": "No traction — revisit distribution or value prop" },
        { "range": "10-50 DAU", "meaning": "Early signal — some interest but not enough to validate" },
        { "range": "50-100 DAU", "meaning": "Growing — close to validation threshold" },
        { "range": "100-500 DAU", "meaning": "Validated — enough users to measure retention" },
        { "range": "500+ DAU", "meaning": "Strong traction — ready for growth investment" }
      ],
      "currentValue": null,
      "verificationMethod": "analytics",
      "checkability": "observable",
      "verificationTool": "none",
      "gate": "gate-mvp-launch",
      "status": "not-measured",
      "notes": "Track from launch day"
    },
    {
      "id": "S-002",
      "name": "Return usage",
      "category": "business-metric",
      "metric": "7-day return rate after first worksheet creation",
      "threshold": "> 40%",
      "rubric": [
        { "range": "< 10%", "meaning": "No retention — users try once and leave" },
        { "range": "10-25%", "meaning": "Weak — product doesn't compel return visits" },
        { "range": "25-40%", "meaning": "Moderate — some value but not habit-forming" },
        { "range": "40-60%", "meaning": "Good — users find ongoing value" },
        { "range": "60%+", "meaning": "Excellent — strong product-market fit signal" }
      ],
      "currentValue": null,
      "verificationMethod": "analytics",
      "checkability": "observable",
      "verificationTool": "none",
      "gate": "gate-beta-ready",
      "status": "not-measured",
      "notes": "Leading indicator of product-market fit"
    },
    {
      "id": "S-003",
      "name": "User satisfaction",
      "category": "business-metric",
      "metric": "Average in-app rating",
      "threshold": "> 4.0 / 5.0",
      "rubric": [
        { "range": "< 2.0", "meaning": "Users actively dislike the product" },
        { "range": "2.0-3.0", "meaning": "Below expectations — significant gaps" },
        { "range": "3.0-4.0", "meaning": "Acceptable — meets basic needs but uninspiring" },
        { "range": "4.0-4.5", "meaning": "Good — users are satisfied and would recommend" },
        { "range": "4.5-5.0", "meaning": "Exceptional — strong advocacy potential" }
      ],
      "currentValue": null,
      "verificationMethod": "user-feedback",
      "checkability": "observable",
      "verificationTool": "none",
      "gate": "gate-beta-ready",
      "status": "not-measured",
      "notes": "Prompt after 3rd worksheet creation"
    }
  ],

  "gates": [
    {
      "id": "gate-mvp-launch",
      "name": "MVP Launch Ready",
      "description": "All core functionality works, performs acceptably, users can complete primary flow",
      "criteria": ["S-001"],
      "status": "blocked",
      "passedAt": null,
      "verifiableStatus": "passed",
      "verifiablePassedAt": null
    },
    {
      "id": "gate-beta-ready",
      "name": "Beta Ready",
      "description": "MVP criteria met plus user perception validated and retention proven",
      "criteria": ["S-002", "S-003"],
      "status": "blocked",
      "passedAt": null,
      "verifiableStatus": "passed",
      "verifiablePassedAt": null
    }
  ],

  "summary": {
    "totalCriteria": 3,
    "byStatus": { "not-measured": 3, "below-threshold": 0, "at-threshold": 0, "exceeded": 0 },
    "byCheckability": { "verifiable": 0, "observable": 3 }
  }
}
